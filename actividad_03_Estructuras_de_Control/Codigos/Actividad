/////////Ejercicio 2
int opcion, cal, i;
float suma, resu, g;
int aprobada = 0, reprobada = 0;
do{
    printf("Ingresa la cantidad de calificaciones: ");
    scanf("%d", &cal);
    for(i=0; i<cal; i++){
        do{
            printf("Ingresa una calificacion: ");
            scanf("%f", &g);
            if( g > 100 || g < 0 ){
                printf("No es una calificacion valida\n");
            }
        }while( g > 100 || g < 0 );
        if( g >= 60 ){
            aprobada++;
        }else{
            reprobada++;
        }
        suma += g;
    }
    resu = suma/cal;

    printf("El promedio es %.2f\n", resu);
    printf("Cantidad de materias aprobadas %d y reprobadas %d\n", aprobada, reprobada);

    printf("1. Ingresar otras calificaciones: \n");
    printf("2. Salir\n");
    scanf("%d", &opcion);
}while( opcion != 2 );
